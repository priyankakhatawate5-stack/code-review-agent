# GitHub Configuration (required)
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=

# OpenCode / GitHub Copilot Configuration
# Run `opencode serve` before starting the agent
# Auth is handled by opencode — no API key needed here
OPENCODE_BASE_URL=http://localhost:4096/v1
OPENCODE_MODEL=gpt-4o

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Agent Configuration
ENABLE_AUTO_APPROVE=false
CRITICAL_SEVERITY_THRESHOLD=8
MAX_ANALYSIS_TIME_SECONDS=60
